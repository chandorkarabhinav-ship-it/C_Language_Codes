#include <stdio.h>

int main() {
    int n, i;
    printf("Enter size: ");
    scanf("%d", &n);

    int a[n], b[n], sum[n];

    for(i=0; i<n; i++) scanf("%d", &a[i]);
    for(i=0; i<n; i++) scanf("%d", &b[i]);

    for(i=0; i<n; i++) sum[i] = a[i] + b[i];

    for(i=0; i<n; i++) printf("%d ", sum[i]);
    return 0;
}
