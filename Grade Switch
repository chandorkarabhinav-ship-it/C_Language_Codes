#include <stdio.h>

int main() {
    int marks;
    printf("Enter your marks (0-100): ");
    scanf("%d", &marks);

    switch (marks / 10) {
        case 10: // For marks = 100
        case 9:  // For marks between 90-99
            printf("Grade: A\n");
            break;
        case 8:  // For marks between 80-89
            printf("Grade: B\n");
            break;
        case 7:  // For marks between 70-79
            printf("Grade: C\n");
            break;
        case 6:  // For marks between 60-69
            printf("Grade: D\n");
            break;
        case 5:  // For marks between 50-59
            printf("Grade: E\n");
            break;
        default: // For marks below 50
            printf("Grade: F (Fail)\n");
    }

    return 0;
}
