#include <stdio.h>

int main() {
    int i, j;
    int rows = 3; // change this to control how many lines

    for (i = rows; i >= 1; i--) {
        for (j = 0; j < i; j++) {
            printf("*");
        }
        printf("\n");
    }

    return 0;
}
