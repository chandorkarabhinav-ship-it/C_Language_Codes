#include <stdio.h>
int main(){
    int password = 2102, h, i, c = 0;
    for (i = 1; i <= 3; i++) {
        printf("\nEnter your pin: ");
        scanf("%d", &h);

        if (h == password) {
            c = 1;
            printf("\nAccess Granted!\n");
            break;
        } else {
            printf("\nIncorrect pin please try again.\n");
            continue;
        }
    }

    if (!c) {
        printf("Your card has been locked\n");
    }

    return 0;
}
